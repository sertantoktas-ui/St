# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False
FLASK_APP=app.py

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/service_management
DB_NAME=service_management
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-change-in-production-use-random-string

# Google Maps API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Stripe Payment Gateway
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# Email Configuration (SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@servicemanagement.com

# SendGrid Configuration (Alternative)
SENDGRID_API_KEY=your-sendgrid-api-key

# Redis Cache & Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# World Clock Configuration
REPORTS_TIMEZONE=Europe/Istanbul
REPORT_EMAIL_HOUR=09
REPORT_EMAIL_MINUTE=00

# Application Settings
API_TITLE=Enterprise Service Management System
API_VERSION=1.0.0
LOG_LEVEL=INFO
